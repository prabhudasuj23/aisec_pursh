# ── AISec backend ─────────────────────────────────────────────────────────────
# Copy to .env.local and fill in real values. Never commit .env.local.

# Supabase project for AISec OIDC auth (aivistix.com Supabase project)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_JWT_SECRET=YOUR_SUPABASE_JWT_SECRET

# Postgres (RDS or Supabase direct connection)
DATABASE_URL=postgresql+asyncpg://aisec:PASSWORD@localhost:5432/aisec

# AWS
AWS_REGION=us-east-1
ENVIRONMENT=local
