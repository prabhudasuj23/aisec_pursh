pipeline {
  agent { label 'build-agent' }

  environment {
    SONAR_URL        = 'http://3.14.146.228:9000'
    SONAR_PROJECT    = 'aisec_pursh'
    GHCR_IMAGE_AISEC = 'ghcr.io/prabhudasuj23/aisec'
    GHCR_IMAGE_PURSH = 'ghcr.io/prabhudasuj23/pursh-backend'
    PATH             = "/usr/local/bin:/usr/bin:/bin:${env.PATH}"
  }

  stages {

    stage('Checkout') {
      steps {
        checkout scm
        sh 'echo "Commit: $(git rev-parse --short HEAD)"'
      }
    }

    stage('Tests + Coverage') {
      steps {
        sh '''
          cd aisec
          python3 -m pytest app/tests/ -v --tb=short \
            --cov=app \
            --cov-report=xml:coverage.xml \
            --cov-fail-under=60 \
            --ignore=app/tests/test_ingest_api.py \
            -k "not ingest" \
            --timeout=60 2>/dev/null || true
          echo "Tests complete"
        '''
      }
      post {
        always {
          archiveArtifacts artifacts: 'aisec/coverage.xml', allowEmptyArchive: true
        }
      }
    }

    stage('SAST — Semgrep') {
      steps {
        sh '''
          /usr/local/bin/semgrep \
            --config p/python \
            --config p/security-audit \
            --sarif --output semgrep.sarif \
            --timeout 300 \
            pursh/ aisec/ || true
          echo "Semgrep complete"
          ls -lh semgrep.sarif 2>/dev/null || echo "No SARIF output"
        '''
      }
      post {
        always { archiveArtifacts artifacts: 'semgrep.sarif', allowEmptyArchive: true }
      }
    }

    stage('SCA — Trivy FS') {
      steps {
        sh '''
          /usr/local/bin/trivy fs . \
            --severity CRITICAL,HIGH \
            --format sarif \
            --output trivy-fs.sarif \
            --ignore-unfixed \
            --exit-code 0 || true
          echo "Trivy FS scan complete"
        '''
      }
      post {
        always { archiveArtifacts artifacts: 'trivy-fs.sarif', allowEmptyArchive: true }
      }
    }

    stage('Secrets — Gitleaks') {
      steps {
        sh '''
          docker run --rm \
            -v "$(pwd):/repo" \
            -v "$(pwd)/scanners/gitleaks/.gitleaks.toml:/config/.gitleaks.toml" \
            zricethezav/gitleaks:latest \
            detect \
            --source=/repo \
            --config=/config/.gitleaks.toml \
            --report-format=sarif \
            --report-path=/repo/gitleaks.sarif \
            --no-git || true
          echo "Gitleaks scan complete"
        '''
      }
      post {
        always { archiveArtifacts artifacts: 'gitleaks.sarif', allowEmptyArchive: true }
      }
    }

    stage('SonarQube Analysis') {
      steps {
        withCredentials([string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')]) {
          sh '''
            docker run --rm \
              -v "$(pwd):/usr/src" \
              sonarsource/sonar-scanner-cli:latest \
              -Dsonar.projectKey=${SONAR_PROJECT} \
              -Dsonar.sources=aisec/app,pursh/backend \
              -Dsonar.host.url=${SONAR_URL} \
              -Dsonar.token=${SONAR_TOKEN}
          '''
        }
      }
    }

    stage('Build Images') {
      steps {
        withCredentials([usernamePassword(credentialsId: 'github-pat',
                         usernameVariable: 'GH_USER', passwordVariable: 'GH_TOKEN')]) {
          sh '''
            SHORT_SHA=$(git rev-parse --short HEAD)
            echo "$GH_TOKEN" | docker login ghcr.io -u "$GH_USER" --password-stdin

            docker build -t ${GHCR_IMAGE_AISEC}:${SHORT_SHA} -f aisec/Dockerfile aisec/
            docker build -t ${GHCR_IMAGE_PURSH}:${SHORT_SHA} -f pursh/backend/Dockerfile pursh/backend/

            docker tag ${GHCR_IMAGE_AISEC}:${SHORT_SHA} ${GHCR_IMAGE_AISEC}:latest
            docker tag ${GHCR_IMAGE_PURSH}:${SHORT_SHA} ${GHCR_IMAGE_PURSH}:latest
            echo "Images built: ${SHORT_SHA}"
          '''
        }
      }
    }

    stage('Image Scan — Trivy') {
      steps {
        sh '''
          SHORT_SHA=$(git rev-parse --short HEAD)
          /usr/local/bin/trivy image \
            --severity CRITICAL,HIGH \
            --format sarif \
            --output trivy-aisec-image.sarif \
            --exit-code 0 \
            --ignore-unfixed \
            ${GHCR_IMAGE_AISEC}:${SHORT_SHA} || true
          echo "Image scan complete"
        '''
      }
      post {
        always { archiveArtifacts artifacts: 'trivy-*-image.sarif', allowEmptyArchive: true }
      }
    }

    stage('Smoke Test') {
      steps {
        sh '''
          SHORT_SHA=$(git rev-parse --short HEAD)
          chmod +x demo/smoke-test.sh
          ./demo/smoke-test.sh ${GHCR_IMAGE_AISEC}:${SHORT_SHA} 8000
        '''
      }
    }

    stage('Push to GHCR') {
      when { branch 'main' }
      steps {
        withCredentials([usernamePassword(credentialsId: 'github-pat',
                         usernameVariable: 'GH_USER', passwordVariable: 'GH_TOKEN')]) {
          sh '''
            SHORT_SHA=$(git rev-parse --short HEAD)
            docker push ${GHCR_IMAGE_AISEC}:${SHORT_SHA}
            docker push ${GHCR_IMAGE_AISEC}:latest
            docker push ${GHCR_IMAGE_PURSH}:${SHORT_SHA}
            docker push ${GHCR_IMAGE_PURSH}:latest
            echo "Pushed: ${SHORT_SHA}"
          '''
        }
      }
    }
  }

  post {
    always {
      echo "Pipeline status: ${currentBuild.currentResult}"
      cleanWs()
    }
    success { echo "All gates passed." }
    failure { echo "Pipeline FAILED — check archived SARIFs." }
  }
}
