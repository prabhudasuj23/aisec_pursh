# Pursh backend environment variables (all prefixed PURSH_)
# Copy to .env.local and fill in real values.

PURSH_SUPABASE_URL=https://YOUR_PURSH_PROJECT_REF.supabase.co
PURSH_SUPABASE_ANON_KEY=YOUR_PURSH_ANON_KEY
PURSH_SUPABASE_SERVICE_ROLE_KEY=YOUR_PURSH_SERVICE_ROLE_KEY
PURSH_DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
PURSH_AWS_REGION=us-east-1
PURSH_S3_BUCKET_LAB_RESULTS=pursh-lab-results-staging
PURSH_ENVIRONMENT=local
