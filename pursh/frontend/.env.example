# Pursh frontend environment variables
# Copy to .env.local and fill in real values.

# Supabase project for Pursh auth (separate from AISec Supabase)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PURSH_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_PURSH_ANON_KEY

# Pursh backend API URL
NEXT_PUBLIC_PURSH_API_URL=http://localhost:8001
